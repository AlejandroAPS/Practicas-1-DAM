<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<VBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.demojavafx.HelloController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label text="Equipo local"/>
    <TextField fx:id="equipoLocal"/>

    <Label text="Equipo visitante"/>
    <TextField fx:id="equipoVisitante"/>

    <Label text="Goles equipo local"/>
    <TextField fx:id="golesLocal"/>

    <Label text="Goles equipo visitante"/>
    <TextField fx:id="golesVisitante"/>


    <Label fx:id="enviaResultado"/>
    <Button text="Comprobar Resultado" onAction="#onButtonClick"/>

</VBox>
